<!DOCTYPE html>
<html>
<head>
    <meta charset="UTF-8">
    <style>
        @page {
            size: A4;
            margin: 5mm 5mm 5mm 5mm;
            @bottom-center {
                content: none;
            }
        }
        body {
            font-family: 'Times New Roman', Times, serif;
            color: #0f172a;
            line-height: 1.2;
            margin: 0;
            padding: 0;
            background: #ffffff;
        }
        
        /* ── Watermark ── */
        .watermark-container {
            position: absolute;
            top: 50%;
            left: 50%;
            transform: translate(-50%, -50%) rotate(-45deg);
            pointer-events: none;
            z-index: 0;
            user-select: none;
            white-space: nowrap;
            font-size: 80pt;
            font-weight: 900;
            opacity: 0.025;
            color: #0f172a;
        }

        .relative-container {
            position: relative;
            z-index: 10;
            /* Standard board paper: 10mm inside the border, and a minimal 4mm top cushion inside the border */
            padding: 4mm 10mm 10mm 10mm;
        }

        .school-header {
            text-align: center;
            margin-bottom: 2pt;
        }
        
        .school-name {
            font-size: 20pt;
            font-weight: 900;
            text-transform: uppercase;
            margin: 0;
            letter-spacing: 0.5px;
            line-height: 1.1;
        }

        /* Fix 3: Show institution name instead of address */
        .school-institution {
            font-size: 8pt;
            color: #475569;
            font-weight: 500;
            margin: 2pt 0 0 0;
        }

        .double-divider {
            border-top: 3px solid #000;
            border-bottom: 1px solid #000;
            height: 2px;
            margin-bottom: 4pt;
            margin-top: 4pt;
        }

        .info-row {
            display: grid;
            grid-template-columns: 1fr 1fr 1fr;
            font-size: 9pt;
            font-weight: bold;
            margin-bottom: 1pt;
        }

        .info-row > *:nth-child(1) {
            text-align: left;
        }

        .info-row > *:nth-child(2) {
            text-align: center;
        }

        .info-row > *:nth-child(3) {
            text-align: right;
        }

        .info-row-title {
            font-weight: 900;
            text-decoration: underline;
            font-size: 10pt;
        }

        .instructions-box {
            border: 1px solid #000;
            padding: 6px 10px;
            margin-top: 5pt;
            margin-bottom: 8pt;
            font-size: 8pt;
        }

        .instructions-title {
            font-weight: 900;
            text-transform: uppercase;
            text-decoration: underline;
            margin-bottom: 2pt;
            font-size: 8.5pt;
        }

        .instruction-line {
            display: flex;
            gap: 6px;
            margin-bottom: 1pt;
            font-weight: 600;
            color: #1e293b;
            line-height: 1.2;
            page-break-inside: avoid;
        }

        .section-separator {
            border-top: 2px solid #000;
            margin-bottom: 10pt;
            margin-top: 5pt;
        }

        .questions-container {
            display: block;
        }

        /* Fix 5: Proper question layout with left margin */
        .question-item {
            display: flex;
            align-items: flex-start;
            page-break-inside: avoid;
            width: 100%;
            justify-content: space-between;
            gap: 30px;
            margin-top: 8pt;
        }

        .q-number {
            width: 32px;
            font-weight: normal;
            font-size: 10pt;
            flex-shrink: 0;
        }

        .q-body {
            flex: 1;
        }

        .q-text-row {
            display: flex;
            justify-content: space-between;
            align-items: flex-start;
            gap: 30px;
        }

        .q-text {
            font-size: 10pt;
            font-weight: normal;
            color: #0f172a;
            line-height: 1.2;
            white-space: pre-wrap;
            flex: 1;
        }

        .q-marks-label {
            font-size: 9pt;
            font-weight: bold;
            color: #334155;
            white-space: nowrap;
            flex-shrink: 0;
        }

        /* ── MCQ Grid ── */
        .options-grid {
            display: grid;
            grid-template-columns: 1fr 1fr;
            gap: 2pt 15pt;
            margin-top: 4pt;
        }

        .option-item {
            display: flex;
            gap: 6px;
            font-size: 9.5pt;
            font-weight: normal;
            page-break-inside: avoid;
        }

        .option-label {
            font-weight: bold;
        }

        /* ── True / False ── */
        .tf-container {
            display: flex;
            gap: 20pt;
            margin-top: 4pt;
        }

        .tf-item {
            display: flex;
            align-items: center;
            gap: 6px;
            font-size: 9.5pt;
            font-weight: normal;
            page-break-inside: avoid;
        }

        .tf-circle {
            height: 9pt;
            width: 9pt;
            border-radius: 50%;
            border: 1.5px solid #000;
            display: inline-block;
        }

        /* ── Match columns ── */
        .match-table {
            width: 100%;
            border-collapse: collapse;
            margin-top: 4pt;
            font-size: 9pt;
        }

        .match-table th, .match-table td {
            border: 1px solid #000;
            padding: 3pt 8pt;
            text-align: left;
        }

        .match-table th {
            background-color: #f8fafc;
            font-weight: 900;
        }

        .match-table td {
            font-weight: normal;
        }

        /* ── Passage Box ── */
        .passage-box {
            border: 1px solid #000;
            padding: 8pt;
            margin-top: 6pt;
            margin-bottom: 6pt;
            background-color: #ffffff;
            font-size: 9.5pt;
            font-weight: 500;
            line-height: 1.3;
            white-space: pre-wrap;
        }

        /* ── Case Based ── */
        .case-sub-questions {
            margin-top: 5pt;
            margin-left: 15pt;
            display: block;
        }

        .case-sub-question-row {
            display: flex;
            justify-content: space-between;
            align-items: flex-start;
            gap: 30px;
            margin-top: 4pt;
            page-break-inside: avoid;
        }

        .case-sub-q-body {
            display: flex;
            align-items: flex-start;
            gap: 6px;
            flex: 1;
        }

        /* Fix 6: Normal weight for case sub-question labels */
        .case-sub-q-label {
            font-weight: normal;
            font-size: 9.5pt;
            flex-shrink: 0;
        }

        .case-sub-q-text {
            font-size: 9.5pt;
            font-weight: normal;
            color: #0f172a;
            line-height: 1.2;
            flex: 1;
        }

        .case-sub-q-marks {
            font-size: 9pt;
            font-weight: normal;
            color: #475569;
            flex-shrink: 0;
            white-space: nowrap;
        }

        .activity-item {
            margin-top: 8pt;
            page-break-inside: avoid;
        }

        .activity-header {
            display: flex;
            justify-content: space-between;
            align-items: baseline;
            gap: 30px;
            margin-bottom: 4pt;
        }

        .activity-title {
            font-size: 9.5pt;
            font-weight: 900;
            color: #0f172a;
        }

        .activity-marks {
            font-size: 9.5pt;
            font-weight: 900;
            color: #0f172a;
            white-space: nowrap;
        }

        .sub-questions-list {
            padding-left: 15pt;
            display: block;
        }

        .sub-question-row {
            display: flex;
            align-items: flex-start;
            gap: 8px;
            margin-top: 4pt;
            page-break-inside: avoid;
        }

        /* Fix 6: Normal weight for sub-question roman numerals */
        .sub-q-roman {
            font-weight: normal;
            font-size: 9.5pt;
            width: 25px;
            text-align: right;
            flex-shrink: 0;
        }

        .sub-q-text {
            font-size: 9.5pt;
            font-weight: normal;
            color: #0f172a;
            line-height: 1.2;
            white-space: pre-wrap;
            flex: 1;
        }

        /* Fix 8: Word limit inline — displayed as inline span, not block */
        .word-limit-inline {
            font-size: 8.5pt;
            font-weight: normal;
            font-style: italic;
            color: #64748b;
            display: inline;
            margin-left: 6px;
        }

        /* Fix 2: Simplified footer — only asterisks */
        .paper-footer {
            margin-top: 20pt;
            display: flex;
            justify-content: center;
            align-items: center;
            page-break-inside: avoid;
        }

        .footer-asterisk {
            font-size: 11pt;
            font-weight: 900;
            letter-spacing: 5px;
            color: #1e293b;
        }

        /* ── Bullet list (Letter) ── */
        .bullets-box {
            margin-top: 4pt;
            border-left: 2px solid #cbd5e1;
            padding-left: 10pt;
            margin-left: 10pt;
        }

        .bullets-title {
            font-size: 9pt;
            font-weight: 900;
            color: #475569;
            margin-bottom: 1pt;
        }

        .bullet-line {
            font-size: 9.5pt;
            font-weight: normal;
            display: flex;
            gap: 6px;
            line-height: 1.2;
            page-break-inside: avoid;
        }

        /* ── Diagram Labels grid ── */
        .labels-grid {
            display: grid;
            grid-template-columns: 1fr 1fr;
            gap: 3pt;
            margin-top: 4pt;
        }

        .label-item {
            display: flex;
            gap: 6px;
            font-size: 9.5pt;
            font-weight: normal;
            page-break-inside: avoid;
        }

        /* ── Solid Page Border Frame ── */
        .page-border {
            position: fixed;
            top: 0;
            left: 0;
            right: 0;
            bottom: 0;
            border: 2px solid #000;
            pointer-events: none;
            z-index: 1000;
            box-sizing: border-box;
        }

        /* Fix 5: Questions starting on a new page get top padding */
        .section-container {
            padding-top: 8pt;
        }
    </style>
</head>
<body>
    <div class="page-border"></div>
    <%
      const romanize = (num) => {
        const lookup = {
          1: "i", 2: "ii", 3: "iii", 4: "iv", 5: "v",
          6: "vi", 7: "vii", 8: "viii", 9: "ix", 10: "x",
          11: "xi", 12: "xii", 13: "xiii", 14: "xiv", 15: "xv",
          16: "xvi", 17: "xvii", 18: "xviii", 19: "xix", 20: "xx"
        };
        return lookup[num] || num.toString();
      };

      const getQuestionLetter = (qText, defaultLetter = "B") => {
        const match = qText ? qText.match(/\(([A-Z])\)/) : null;
        return match ? match[1] : defaultLetter;
      };

      const getActivityHeading = (act) => {
        if (act.heading && act.heading.trim()) return act.heading;
        const lookup = {
          "True / False": "Write whether the following sentences are 'True' or 'False':",
          "MCQ": "Choose the correct alternative:",
          "Give Reasons": "Give reasons for the following:",
          "Vocabulary": "Write antonyms/synonyms from the extract:",
          "Grammar": "Grammar / Do as Directed:",
          "Do as Directed": "Do as Directed:",
          "One Line Answers": "Answer the following in one line:",
          "Personal Response": "Personal Response:",
          "Fill in the Blanks": "Fill in the blanks with correct words:",
          "Match the Following": "Match the columns:"
        };
        return lookup[act.type] || act.type || "Activity";
      };

      const primaryColor = school.primary_color || "#1a1a2e";

      const durationLabel = () => {
        const m = paper.duration_mins;
        if (!m) return "3 Hours";
        if (m < 60) return m + " Minutes";
        const h = Math.floor(m / 60);
        const rem = m % 60;
        return rem > 0 ? h + " Hr " + rem + " Min" : h + " Hour" + (h > 1 ? "s" : "");
      };

      const formatDateStr = (dateVal) => {
        if (!dateVal) return new Date().toLocaleDateString('en-GB');
        try {
          return new Date(dateVal).toLocaleDateString('en-GB');
        } catch(e) {
          return new Date().toLocaleDateString('en-GB');
        }
      };
    %>

    <% if (school.show_watermark) { %>
        <div class="watermark-container">
            <%= school.school_name ? school.school_name.split(' ')[0] : 'SCHOOL' %>
        </div>
    <% } %>

    <div class="relative-container">
        <!-- ── School Header ── -->
        <div class="school-header">
            <h1 class="school-name" style="color: <%= primaryColor %>;"><%= school.school_name || "SCHOOL NAME" %></h1>
            <!-- Fix 3: Show organization_name (institution name) instead of address -->
            <% if (school.organization_name || school.address) { %>
                <p class="school-institution"><%= school.organization_name || school.address %></p>
            <% } %>
        </div>

        <!-- ── Double Line Divider ── -->
        <div class="double-divider"></div>

        <%
          let displayTitle = paper.title || "Examination";
          if (paper.exam_name) {
            displayTitle = paper.exam_name;
          } else if (paper.exam_type) {
            const lookup = {
              unit_test: "Unit Test",
              ca: "Continuous Assessment",
              half_yearly: "Half-Yearly Examination",
              annual: "Annual Examination",
              practice: "Practice Paper"
            };
            displayTitle = lookup[paper.exam_type] || paper.title || "Examination";
          }
          // Strip duplicate "Class Class X" or "Class X" prefixes
          displayTitle = displayTitle.replace(/^Class\s+Class\s+\d+\s*—\s*/i, "");
          displayTitle = displayTitle.replace(/^Class\s+\d+\s*—\s*/i, "");

          let displayClass = paper.class_name || "Class";
          displayClass = displayClass.replace(/^Class\s+/i, "");
        %>
        <!-- ── Exam Info Row 1: Time | Title | Max Marks ── -->
        <div class="info-row">
            <span>Time: <%= durationLabel() %></span>
            <span class="info-row-title" style="color: <%= primaryColor %>;">
                <%= displayTitle %>
            </span>
            <span>Max. Marks: <%= paper.total_marks || 80 %></span>
        </div>

        <!-- ── Exam Info Row 2: Subject | Class | Date ── -->
        <div class="info-row" style="margin-bottom: 4pt;">
            <span>Subject: <%= paper.subject_name || paper.subject || "Subject" %></span>
            <span>Class: <%= displayClass %></span>
            <span>Date: <%= formatDateStr(paper.date_time) %></span>
        </div>

        <!-- ── Instructions Box ── -->
        <% if (paper.instructions) { %>
            <div class="instructions-box">
                <p class="instructions-title">Instructions:</p>
                <div>
                    <% paper.instructions.split('\n').filter(Boolean).forEach(function(line, i) { %>
                        <div class="instruction-line">
                            <span style="flex-shrink: 0;"><%= i + 1 %>.</span>
                            <span><%= line.replace(/^\d+\.\s*/, "") %></span>
                        </div>
                    <% }); %>
                </div>
            </div>
        <% } %>

        <!-- ── Section Separator ── -->
        <div class="section-separator"></div>

        <!-- ── Questions List ── -->
        <div class="questions-container">
            <% 
               let hasQuestions = false;
               if (paper.sections) {
                   paper.sections.forEach(function(sec) {
                       if (sec.questions && sec.questions.length > 0) {
                           hasQuestions = true;
                       }
                   });
               }
            %>
            <% if (!hasQuestions) { %>
                <div style="text-align: center; padding: 40pt; opacity: 0.3; font-weight: bold;">
                    Questions will appear here as you add them.
                </div>
            <% } else { %>
                <% 
                   let globalQNum = 0;
                   const getSectionTitle = function(name) {
                       const lookup = {
                           MCQ: "Solve the MCQs",
                           FILL_BLANKS: "Fill in the blanks",
                           TRUE_FALSE: "State whether True or False",
                           MATCH_FOLLOWING: "Match the following Columns",
                           VERY_SHORT: "Answer the following questions in one line each",
                           SHORT_ANSWER: "Answer the following questions in brief (Short Answers)",
                           LONG_ANSWER: "Answer the following questions in detail (Long Answers)",
                           PASSAGE_BASED: "Read the following passage and do the activities",
                           DIAGRAM_LABEL: "Label the given diagram according to instructions",
                           NUMERICAL: "Solve the following calculations",
                           WORD_PROBLEM: "Solve the following word problems",
                           GIVE_REASONS: "Give reasons for the following",
                           LETTER: "Letter Writing",
                           ESSAY: "Essay Writing",
                           CASE_BASED: "Read the case study and answer the questions"
                       };
                       return lookup[name] || name;
                   };

                   paper.sections.forEach(function(sec, secIdx) { 
                       if (!sec.questions || sec.questions.length === 0) return;
                       globalQNum++;
                       const secTitle = getSectionTitle(sec.section_name);
                       const secMarks = sec.questions.reduce((sum, q) => sum + (q.marks || 0), 0);
                %>
                    <!-- Fix 5: section-container with padding-top so new-page sections aren't cramped -->
                    <div class="section-container" style="page-break-inside: auto; margin-bottom: 10pt; width: 100%;">
                        <!-- Section Header -->
                         <div style="display: flex; justify-content: space-between; align-items: baseline; padding-bottom: 2pt; margin-bottom: 6pt; width: 100%; gap: 30px;">
                             <span style="font-weight: 900; font-size: 10.5pt; letter-spacing: 0.5px; color: #000; flex: 1; min-width: 0;">
                                 Q.<%= globalQNum %> <%= secTitle %>
                             </span>
                             <div style="width: 70px; text-align: right; flex-shrink: 0;">
                                 <span style="font-size: 10pt; font-weight: 900; color: #000; white-space: nowrap;">
                                     [<%= secMarks %> Marks]
                                 </span>
                             </div>
                         </div>

                        <!-- Questions Under Section -->
                        <!-- Fix 5: Reduced gap between questions for tighter board-style spacing -->
                        <div style="display: block;">
                            <% sec.questions.forEach(function(q, qIdx) { %>
                                <% const roman = romanize(qIdx + 1); %>
                                <!-- Fix 5: no extra padding-left; container padding handles indentation -->
                                <div class="question-item" style="display: flex; align-items: flex-start; width: 100%;">
                                    <div style="display: flex; flex: 1; min-width: 0;">
                                        <!-- Left Roman Number — Fix 6: font-weight: normal -->
                                        <span class="q-number" style="text-align: right; padding-right: 6px; width: 28px; flex-shrink: 0; font-weight: normal;"><%= roman %>)</span>
                                        
                                        <!-- Question Body -->
                                        <div class="q-body" style="flex: 1; min-width: 0;">
                                            <div class="q-text-row">
                                                <!-- Fix 8: Word limit displayed inline after question text -->
                                                <div style="flex: 1;">
                                                    <% if (q.question_text) { %>
                                                        <span class="q-text"><%- q.question_text %></span>
                                                    <% } else if (q.question_type !== "MATCH_FOLLOWING") { %>
                                                        <span class="q-text">…</span>
                                                    <% } %>
                                                    <% const qd = q.question_data || {}; %>
                                                    <% if (q.question_type === "ESSAY" && qd.word_limit) { %>
                                                        <span class="word-limit-inline">(Word Limit: <%= qd.word_limit %>)</span>
                                                    <% } %>
                                                </div>
                                            </div>

                                        <% if (qd.diagram_url) { %>
                                            <% 
                                               let imgSrc = qd.diagram_url;
                                               if (!imgSrc.startsWith('http') && !imgSrc.startsWith('data:')) {
                                                   imgSrc = 'http://localhost:5000' + imgSrc;
                                               }
                                            %>
                                            <div class="q-diagram-box" style="margin-top: 6pt; margin-bottom: 6pt; max-width: 280px;">
                                                <img src="<%= imgSrc %>" alt="Diagram" style="max-height: 220px; max-width: 100%; object-fit: contain; border: 1px solid #e2e8f0; border-radius: 4px;" />
                                            </div>
                                        <% } %>

                                        <!-- MCQ Options -->
                                        <% if (q.question_type === "MCQ" && qd.options) { %>
                                            <div class="options-grid">
                                                <% qd.options.forEach(function(opt, optIdx) { %>
                                                    <% if (opt && opt.trim()) { %>
                                                        <div class="option-item">
                                                            <span class="option-label"><%= String.fromCharCode(65 + optIdx) %>)</span>
                                                            <span><%= opt %></span>
                                                        </div>
                                                    <% } %>
                                                <% }); %>
                                            </div>
                                        <% } %>

                                        <!-- True / False -->
                                        <% if (q.question_type === "TRUE_FALSE") { %>
                                            <div class="tf-container">
                                                <div class="tf-item">
                                                    <div class="tf-circle"></div>
                                                    <span>True</span>
                                                </div>
                                                <div class="tf-item">
                                                    <div class="tf-circle"></div>
                                                    <span>False</span>
                                                </div>
                                            </div>
                                        <% } %>

                                        <!-- Match the Following -->
                                        <% if (q.question_type === "MATCH_FOLLOWING" && qd.col_a) { %>
                                            <table class="match-table">
                                                <thead>
                                                    <tr>
                                                        <th>Column A</th>
                                                        <th>Column B</th>
                                                    </tr>
                                                </thead>
                                                <tbody>
                                                    <% (qd.col_a || []).forEach(function(a, colIdx) { %>
                                                        <tr>
                                                            <td>
                                                                <span style="font-weight: 900; margin-right: 4px;"><%= colIdx + 1 %>.</span>
                                                                <span><%= a %></span>
                                                            </td>
                                                            <td>
                                                                <span style="font-weight: 900; margin-right: 4px;">(<%= String.fromCharCode(97 + colIdx) %>)</span>
                                                                <span><%= qd.col_b ? qd.col_b[colIdx] : "" %></span>
                                                            </td>
                                                        </tr>
                                                    <% }); %>
                                                </tbody>
                                            </table>
                                        <% } %>

                                        <!-- Diagram Label -->
                                        <% if (q.question_type === "DIAGRAM_LABEL" && qd.labels) { %>
                                            <p style="font-size: 9pt; font-weight: normal; font-style: italic; color: #475569; margin: 3pt 0;">
                                                Label the following in the given diagram:
                                            </p>
                                            <div class="labels-grid">
                                                <% qd.labels.forEach(function(lbl, lblIdx) { %>
                                                    <% if (lbl && lbl.trim()) { %>
                                                        <div class="label-item">
                                                            <span style="font-weight: bold;"><%= lblIdx + 1 %>.</span>
                                                            <span><%= lbl %></span>
                                                        </div>
                                                    <% } %>
                                                <% }); %>
                                            </div>
                                        <% } %>

                                        <!-- Letter writing bullet points -->
                                        <% if (q.question_type === "LETTER" && qd.bullet_points) { %>
                                            <div class="bullets-box">
                                                <p class="bullets-title" style="font-weight: bold;">Points to cover:</p>
                                                <div>
                                                    <% qd.bullet_points.filter(pt => pt && pt.trim()).forEach(function(pt) { %>
                                                        <div class="bullet-line">
                                                            <span>•</span><span><%= pt %></span>
                                                        </div>
                                                    <% }); %>
                                                </div>
                                            </div>
                                        <% } %>

                                        <!-- Passage Based Board Rendering -->
                                        <% if (q.question_type === "PASSAGE_BASED") { %>
                                            <%
                                              let activities = qd.activities;
                                              if (!activities) {
                                                activities = [
                                                  {
                                                    id: "legacy",
                                                    heading: "Answer the following questions based on the passage:",
                                                    marks: q.marks || 8,
                                                    type: "One Line Answers",
                                                    sub_questions: qd.sub_questions ? qd.sub_questions.map(sq => typeof sq === "string" ? sq : sq.text || "") : []
                                                  }
                                                ];
                                              }
                                              const qLetter = getQuestionLetter(q.question_text || "", "B");
                                            %>
                                            <div style="margin-top: 4pt;">
                                                <!-- 1. Reading Passage Box -->
                                                <% if (qd.passage) { %><div class="passage-box"><%= qd.passage %></div><% } %>

                                                <!-- 2. Activities -->
                                                <% activities.forEach(function(act, actIdx) { %>
                                                    <% const headingNum = qLetter + (actIdx + 1); %>
                                                    <div class="activity-item">
                                                        <div class="activity-header">
                                                            <span class="activity-title">
                                                                <%= headingNum %>. <%= getActivityHeading(act) %>
                                                            </span>
                                                            <span class="activity-marks">
                                                                (<%= act.marks || 2 %>)
                                                            </span>
                                                        </div>

                                                        <% if (act.sub_questions && act.sub_questions.length > 0) { %>
                                                            <div class="sub-questions-list">
                                                                <% act.sub_questions.forEach(function(subQ, subIdx) { %>
                                                                    <% const romanSub = "(" + romanize(subIdx + 1) + ")"; %>
                                                                    <% const sqText = typeof subQ === "string" ? subQ : subQ?.text || ""; %>
                                                                    <% const sqMarks = typeof subQ === "string" ? null : subQ?.marks; %>
                                                                    <div class="sub-question-row" style="display: flex; justify-content: space-between; align-items: flex-start; gap: 30px; width: 100%;">
                                                                        <div style="display: flex; align-items: flex-start; gap: 8px; flex: 1;">
                                                                            <!-- Fix 6: font-weight normal on sub-question roman label -->
                                                                            <span class="sub-q-roman" style="font-weight: normal;"><%= romanSub %></span>
                                                                            <div class="sub-q-text"><%= sqText || "…" %></div>
                                                                        </div>
                                                                        <% if (sqMarks !== null && sqMarks !== undefined) { %>
                                                                            <span style="font-size: 9pt; font-weight: normal; color: #475569; flex-shrink: 0; white-space: nowrap;">[<%= sqMarks %>M]</span>
                                                                        <% } %>
                                                                    </div>
                                                                <% }); %>
                                                            </div>
                                                        <% } %>
                                                    </div>
                                                <% }); %>
                                            </div>
                                        <% } %>

                                        <!-- CASE_BASED Legacy Rendering -->
                                        <% if (q.question_type === "CASE_BASED" && qd.sub_questions && qd.sub_questions.length > 0) { %>
                                            <div class="case-sub-questions">
                                                <% qd.sub_questions.forEach(function(sq, i) { %>
                                                    <div class="case-sub-question-row">
                                                        <div class="case-sub-q-body">
                                                            <!-- Fix 6: normal weight label -->
                                                            <span class="case-sub-q-label">(<%= String.fromCharCode(97 + i) %>)</span>
                                                            <span class="case-sub-q-text"><%= sq.text || sq || "Sub-question" %></span>
                                                        </div>
                                                        <span class="case-sub-q-marks">[<%= sq.marks || "" %>M]</span>
                                                    </div>
                                                <% }); %>
                                            </div>
                                        <% } %>
                                    </div>
                                    </div>
                                    <div class="q-marks-col" style="width: 70px; text-align: right; flex-shrink: 0;">
                                        <span class="q-marks-label">[<%= q.marks %> Marks]</span>
                                    </div>
                                </div>
                            <% }); %>
                        </div>
                    </div>
                <% }); %>
            <% } %>
        </div>

        <!-- Fix 2: Footer — only the asterisk row, no branding/QP/examiner sign -->
        <div class="paper-footer">
            <div class="footer-asterisk">* * * * *</div>
        </div>
    </div>
</body>
</html>
