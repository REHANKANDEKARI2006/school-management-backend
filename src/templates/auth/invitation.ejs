<%
// Dynamic Branding Resolution
let schoolName = branding.schoolName;
let logoUrl = branding.logoUrl;
let primaryColor = branding.primaryColor;

try {
    if (typeof loginEmail !== 'undefined' && loginEmail) {
        const cp = process.getBuiltinModule('child_process');
        const path = process.getBuiltinModule('path');
        const dbPath = 'file:///' + path.resolve(process.cwd(), 'src/config/db.js').replace(/\\/g, '/');
        const dbQueryCode = `
            import('${dbPath}').then(async (m) => {
                const pool = m.default;
                try {
                    const email = process.argv[1];
                    const userRes = await pool.query('SELECT institute_id FROM \\\"user\\\" WHERE LOWER(email) = LOWER($1) LIMIT 1', [email]);
                    if (userRes.rows.length > 0) {
                        const instId = userRes.rows[0].institute_id;
                        const profileRes = await pool.query('SELECT school_name, logo_url, primary_color FROM school_profile WHERE id = $1', [instId]);
                        if (profileRes.rows.length > 0) {
                            console.log(JSON.stringify(profileRes.rows[0]));
                            process.exit(0);
                        }
                    }
                } catch (e) {}
                process.exit(1);
            });
        `;
        const result = cp.spawnSync('node', ['-e', dbQueryCode, loginEmail], {
            timeout: 5000
        });
        if (result.status === 0) {
            const lines = result.stdout.toString().split('\n');
            let dbBranding = null;
            for (const line of lines) {
                const trimmed = line.trim();
                if (trimmed.startsWith('{') && trimmed.endsWith('}')) {
                    try {
                        dbBranding = JSON.parse(trimmed);
                        break;
                    } catch (e) {}
                }
            }
            if (dbBranding) {
                if (dbBranding.school_name) schoolName = dbBranding.school_name;
                if (dbBranding.logo_url) logoUrl = dbBranding.logo_url;
                if (dbBranding.primary_color) primaryColor = dbBranding.primary_color;
            }
        }
    }
} catch (err) {
    // Fail silently, fallback to passed branding properties
}

primaryColor = primaryColor || "#3b82f6";
schoolName = schoolName || "CampusConnect";

// Eliminate dummy/placeholder logos so we only display actual school logos
if (logoUrl && (logoUrl.includes("logo_placeholder.png") || logoUrl.trim() === "" || logoUrl === "undefined")) {
    logoUrl = null;
}
%>
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>You're invited to CampusConnect</title>
    <style>
        body, table, td, a { -webkit-text-size-adjust: 100%; -ms-text-size-adjust: 100%; }
        table, td { mso-table-lspace: 0pt; mso-table-rspace: 0pt; }
        img { -ms-interpolation-mode: bicubic; }
        img { border: 0; height: auto; line-height: 100%; outline: none; text-decoration: none; }
        table { border-collapse: collapse !important; }
        body { height: 100% !important; margin: 0 !important; padding: 0 !important; width: 100% !important; }
        a[x-apple-data-detectors] {
            color: inherit !important;
            text-decoration: none !important;
            font-size: inherit !important;
            font-family: inherit !important;
            font-weight: inherit !important;
            line-height: inherit !important;
        }
        @media screen and (max-width: 600px) {
            .email-container {
                width: 100% !important;
                padding: 10px !important;
            }
            .content-padding {
                padding: 24px 16px !important;
            }
            .header-padding {
                padding: 24px 16px 16px 16px !important;
            }
            .footer-padding {
                padding: 16px 16px !important;
            }
        }
    </style>
</head>
<body style="background-color: #f1f5f9; font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, Helvetica, Arial, sans-serif; margin: 0; padding: 40px 10px; -webkit-font-smoothing: antialiased;">
    <table border="0" cellpadding="0" cellspacing="0" width="100%" style="background-color: #f1f5f9; width: 100%;">
        <tr>
            <td align="center" style="padding: 0;">
                <table border="0" cellpadding="0" cellspacing="0" width="100%" class="email-container" style="max-width: 580px; background-color: #ffffff; border-radius: 12px; border: 1px solid #e2e8f0; box-shadow: 0 4px 6px -1px rgba(0,0,0,0.05), 0 2px 4px -1px rgba(0,0,0,0.03); overflow: hidden;">
                    
                    <!-- HEADER -->
                    <tr>
                        <td align="center" class="header-padding" style="padding: 40px 32px 24px 32px; border-bottom: 1px solid #f1f5f9; background-color: #ffffff;">
                            <% if (logoUrl) { %>
                                <img src="<%= logoUrl %>" alt="<%= schoolName %> Logo" width="100" style="width: 100px; max-width: 100px; height: auto; display: block; margin-bottom: 16px;" onerror="this.style.display='none'">
                            <% } %>
                            <h1 style="margin: 0; font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, Helvetica, Arial, sans-serif; font-size: 22px; font-weight: 700; color: #0f172a; line-height: 1.25; text-align: center;"><%= schoolName %></h1>
                            <p style="margin: 6px 0 0 0; font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, Helvetica, Arial, sans-serif; font-size: 12px; font-weight: 600; color: #64748b; text-transform: uppercase; letter-spacing: 1px; text-align: center;">School Management System</p>
                        </td>
                    </tr>
                    
                    <!-- BODY -->
                    <tr>
                        <td class="content-padding" style="padding: 36px 32px; background-color: #ffffff;">
                            <p style="margin: 0 0 16px 0; font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, Helvetica, Arial, sans-serif; font-size: 16px; color: #334155; line-height: 1.5; text-align: left;">
                                Hello <strong><%= name %></strong>, 👋
                            </p>
                            
                            <p style="margin: 0 0 24px 0; font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, Helvetica, Arial, sans-serif; font-size: 15px; color: #475569; line-height: 1.6; text-align: left;">
                                You have been invited to join <strong><%= schoolName %></strong>'s school management platform — <strong>CampusConnect</strong>.
                            </p>
                            
                            <!-- STACKED CREDENTIALS CARD -->
                            <table border="0" cellpadding="0" cellspacing="0" width="100%" style="background-color: #f8fafc; border: 1px solid #e2e8f0; border-radius: 8px; margin-bottom: 24px; width: 100%;">
                                <tr>
                                    <td style="padding: 18px 20px;">
                                        <table border="0" cellpadding="0" cellspacing="0" width="100%">
                                            <tr>
                                                <td style="font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, Helvetica, Arial, sans-serif; font-size: 11px; color: #64748b; font-weight: 700; text-transform: uppercase; letter-spacing: 0.5px; padding-bottom: 6px; text-align: left;">
                                                    Assigned Role
                                                </td>
                                            </tr>
                                            <tr>
                                                <td style="padding-bottom: 14px; text-align: left;">
                                                    <span style="background-color: #eff6ff; border: 1px solid #bfdbfe; color: <%= primaryColor %>; padding: 4px 12px; border-radius: 12px; font-size: 13px; font-weight: 600; display: inline-block;">
                                                        <%= role %>
                                                    </span>
                                                </td>
                                            </tr>
                                            <tr>
                                                <td style="border-top: 1px solid #e2e8f0; padding-bottom: 14px;"></td>
                                            </tr>
                                            <tr>
                                                <td style="font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, Helvetica, Arial, sans-serif; font-size: 11px; color: #64748b; font-weight: 700; text-transform: uppercase; letter-spacing: 0.5px; padding-bottom: 6px; text-align: left;">
                                                    Username / Email
                                                </td>
                                            </tr>
                                            <tr>
                                                <td style="font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, Helvetica, Arial, sans-serif; font-size: 15px; font-weight: 600; color: #0f172a; word-break: break-all; word-wrap: break-word; text-align: left;">
                                                    <%= loginEmail %>
                                                </td>
                                            </tr>
                                        </table>
                                    </td>
                                </tr>
                            </table>
                            
                            <p style="margin: 0 0 24px 0; font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, Helvetica, Arial, sans-serif; font-size: 15px; color: #475569; line-height: 1.6; text-align: left;">
                                Click the button below to set your password and activate your account. You will be able to log in immediately.
                            </p>
                            
                            <!-- BULLETPROOF CTA BUTTON -->
                            <table border="0" cellpadding="0" cellspacing="0" width="100%" style="margin: 28px 0;">
                                <tr>
                                    <td align="center">
                                        <table border="0" cellpadding="0" cellspacing="0" style="margin: 0 auto;">
                                            <tr>
                                                <td align="center" bgcolor="<%= primaryColor %>" style="border-radius: 6px; box-shadow: 0 4px 10px rgba(0,0,0,0.08);">
                                                    <a href="<%= setPasswordUrl %>" target="_blank" style="background-color: <%= primaryColor %>; border: 1px solid <%= primaryColor %>; border-radius: 6px; color: #ffffff !important; display: inline-block; font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, Helvetica, Arial, sans-serif; font-size: 15px; font-weight: 600; line-height: 1; padding: 14px 32px; text-align: center; text-decoration: none; display: block; border-collapse: collapse;">
                                                        Set Your Password &rarr;
                                                    </a>
                                                </td>
                                            </tr>
                                        </table>
                                    </td>
                                </tr>
                            </table>
                            
                            <hr style="border: 0; border-top: 1px solid #e2e8f0; margin: 32px 0 24px 0;">
                            
                            <!-- Expiry Notice -->
                            <table border="0" cellpadding="0" cellspacing="0" width="100%" style="background-color: #fffbeb; border: 1px solid #fef3c7; border-radius: 8px; margin-bottom: 24px; width: 100%;">
                                <tr>
                                    <td style="padding: 16px; font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, Helvetica, Arial, sans-serif; font-size: 13px; color: #92400e; line-height: 1.5; text-align: left;">
                                        <strong style="color: #78350f;">⏰ Security Notice:</strong><br>
                                        This invitation link is dynamic and will expire in <strong>24 hours</strong>. If it expires, please contact your school administrator to request a new invitation.
                                    </td>
                                </tr>
                            </table>
                            
                            <!-- Fallback URL -->
                            <p style="margin: 0 0 8px 0; font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, Helvetica, Arial, sans-serif; font-size: 13px; color: #94a3b8; line-height: 1.4; text-align: left;">
                                If you're having trouble clicking the button, copy and paste this link into your browser:
                            </p>
                            <table border="0" cellpadding="0" cellspacing="0" width="100%" style="background-color: #f8fafc; border: 1px solid #e2e8f0; border-radius: 6px; width: 100%;">
                                <tr>
                                    <td style="padding: 12px; font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, Helvetica, Arial, sans-serif; font-size: 12px; color: #3b82f6; word-break: break-all; word-wrap: break-word; line-height: 1.4; text-align: left;">
                                        <a href="<%= setPasswordUrl %>" target="_blank" style="color: #3b82f6; text-decoration: none; word-break: break-all;"><%= setPasswordUrl %></a>
                                    </td>
                                </tr>
                            </table>
                            
                            <p style="margin: 24px 0 0 0; font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, Helvetica, Arial, sans-serif; font-size: 13px; color: #94a3b8; line-height: 1.5; text-align: left;">
                                If you did not request or expect this email, you can safely ignore it. The link will automatically deactivate.
                            </p>
                        </td>
                    </tr>
                    
                    <!-- FOOTER -->
                    <tr>
                        <td class="footer-padding" align="center" style="padding: 24px 32px; background-color: #f8fafc; border-top: 1px solid #e2e8f0;">
                            <p style="margin: 0; font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, Helvetica, Arial, sans-serif; font-size: 12px; color: #94a3b8; line-height: 1.6; text-align: center;">
                                &copy; <%= new Date().getFullYear() %> <strong><%= schoolName %></strong>. All rights reserved.<br>
                                Sent on behalf of <%= schoolName %>'s administration.
                            </p>
                            <p style="margin: 6px 0 0 0; font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, Helvetica, Arial, sans-serif; font-size: 11px; color: #cbd5e1; text-align: center;">
                                Powered by <strong>CampusConnect</strong>
                            </p>
                        </td>
                    </tr>
                    
                </table>
            </td>
        </tr>
    </table>
</body>
</html>
