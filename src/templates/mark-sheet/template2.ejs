<%- include('../common/theme_variables', { theme: school.document_theme, is_theme_enabled: school.is_document_theme_enabled }) %>
<style>
@import url('https://fonts.googleapis.com/css2?family=Inter:wght@400;600;700;800&family=Merriweather:ital,wght@0,700;1,400&display=swap');

* {
    box-sizing: border-box;
}
body {
    margin: 0;
    padding: 0;
    font-family: 'Inter', sans-serif;
    color: #1e293b;
    background: #fff;
}
.marksheet-wrapper {
    width: 210mm;
    height: 297mm;
    padding: 10mm;
    position: relative;
    background: white;
    overflow: hidden;
}
/* Border Elements */
.border-outer {
    position: absolute;
    top: 5mm;
    left: 5mm;
    right: 5mm;
    bottom: calc(5mm + 35px);
    border: 3px solid var(--primary-color);
    border-radius: 8px;
    z-index: 1;
}
.border-inner {
    position: absolute;
    top: 6.5mm;
    left: 6.5mm;
    right: 6.5mm;
    bottom: calc(6.5mm + 35px);
    border: 1px solid var(--secondary-color);
    border-radius: 6px;
    z-index: 1;
}
/* Top Left Corner Accent */
.corner-accent {
    position: absolute;
    top: 0;
    left: 0;
    width: 150px;
    height: 150px;
    overflow: hidden;
    z-index: 2;
    border-top-left-radius: 8px;
}
.corner-bg-navy {
    position: absolute;
    top: -50px;
    left: -50px;
    width: 150px;
    height: 150px;
    background: var(--primary-color);
    transform: rotate(45deg);
}
.corner-bg-gold {
    position: absolute;
    top: -30px;
    left: -30px;
    width: 100px;
    height: 100px;
    background: var(--secondary-color);
    transform: rotate(45deg);
}
.corner-bg-navy-inner {
    position: absolute;
    top: -15px;
    left: -15px;
    width: 70px;
    height: 70px;
    background: var(--primary-color);
    transform: rotate(45deg);
}

.content-container {
    position: relative;
    z-index: 10;
    padding-top: 10px;
}

/* Header */
.header {
    text-align: center;
    margin-bottom: 10px;
}
.logo {
    width: 80px;
    height: 80px;
    object-fit: contain;
    margin-bottom: 10px;
}
.school-name {
    font-family: 'Merriweather', serif;
    font-size: 22px;
    font-weight: 700;
    color: var(--primary-color);
    text-transform: uppercase;
    margin: 0 0 2px 0;
    letter-spacing: 1px;
}
.org-name {
    font-family: 'Inter', sans-serif;
    font-size: 13px;
    font-weight: 600;
    color: #475569;
    margin: 0 0 8px 0;
    letter-spacing: 0.3px;
}
.school-contact {
    display: flex;
    justify-content: center;
    align-items: center;
    gap: 15px;
    font-size: 11px;
    color: #334155;
    font-weight: 600;
}
.contact-item {
    display: flex;
    align-items: center;
    gap: 5px;
}
.contact-item svg {
    width: 12px;
    height: 12px;
    fill: var(--primary-color);
}
.divider-line {
    height: 1px;
    background: var(--secondary-color);
    margin: 10px auto;
    /* Offset from left to prevent overlap with the green corner accent (150px wide) */
    width: 72%;
    margin-left: auto;
    margin-right: auto;
    position: relative;
}
.divider-line::before, .divider-line::after {
    content: '';
    position: absolute;
    top: -3px;
    width: 7px;
    height: 7px;
    background: var(--secondary-color);
    transform: rotate(45deg);
}
.divider-line::before { left: -3px; }
.divider-line::after { right: -3px; }

/* Title Banner */
.title-banner-container {
    display: flex;
    justify-content: center;
    align-items: center;
    margin: 10px 0;
    position: relative;
}
.title-banner {
    background: var(--primary-color);
    color: #fff;
    padding: 10px 40px;
    border-radius: 20px;
    font-size: 18px;
    font-weight: 800;
    letter-spacing: 1px;
    position: relative;
    display: inline-flex;
    align-items: center;
    box-shadow: 0 4px 6px -1px rgba(0, 0, 0, 0.1);
}
.title-banner::before, .title-banner::after {
    content: '★';
    color: var(--secondary-color);
    font-size: 14px;
    position: absolute;
    top: 50%;
    transform: translateY(-50%);
}
.title-banner::before { left: 15px; }
.title-banner::after { right: 15px; }
.banner-icon-left, .banner-icon-right {
    position: absolute;
    width: 50px;
}
.banner-icon-left { left: 50px; }
.banner-icon-right { right: 50px; }

.academic-year {
    text-align: center;
    margin-bottom: 10px;
}
.academic-year-badge {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    background: #f8fafc;
    border: 1px solid var(--primary-color);
    padding: 4px 16px;
    border-radius: 16px;
    font-size: 13px;
    font-weight: 700;
    color: var(--primary-color);
}

/* Student Info Box */
.student-info-box {
    border: 1px solid #94a3b8;
    border-radius: 12px;
    padding: 10px 20px;
    background: #f8fafc;
    display: flex;
    justify-content: space-between;
    margin-bottom: 15px;
}
.info-col {
    display: flex;
    flex-direction: column;
    gap: 12px;
    flex: 1;
}
.info-col:last-child {
    border-left: 1px dashed #cbd5e1;
    padding-left: 25px;
}
.info-row {
    display: flex;
    align-items: center;
    font-size: 13px;
}
.info-label {
    display: flex;
    align-items: center;
    gap: 8px;
    width: 120px;
    color: #334155;
    font-weight: 600;
}
.info-label svg {
    width: 16px;
    height: 16px;
    fill: var(--primary-color);
}
.info-value {
    font-weight: 700;
    color: #0f172a;
}

/* Marks Table */
.marks-table-wrapper {
    border: 1px solid var(--primary-color);
    border-radius: 8px;
    overflow: hidden;
    margin-bottom: 15px;
}
table {
    width: 100%;
    border-collapse: collapse;
}
th {
    background: var(--primary-color);
    color: #fff;
    padding: 12px;
    font-size: 13px;
    font-weight: 600;
    text-align: center;
}
th:first-child { text-align: left; padding-left: 20px; }
td {
    padding: 12px;
    font-size: 13px;
    text-align: center;
    font-weight: 600;
    border-bottom: 1px dashed #cbd5e1;
    border-right: 1px dashed #cbd5e1;
}
td:last-child { border-right: none; }
td:first-child { text-align: left; padding-left: 20px; color: #334155; }
tr:last-child td { border-bottom: none; }

.empty-state {
    padding: 40px;
    text-align: center;
    color: #64748b;
}
.empty-state svg {
    width: 80px;
    height: 80px;
    margin-bottom: 15px;
    fill: #cbd5e1;
}

/* Summary Cards */
.summary-container {
    display: flex;
    gap: 15px;
    margin-bottom: 15px;
}
.summary-card {
    flex: 1;
    border-radius: 10px;
    padding: 15px;
    display: flex;
    align-items: center;
    gap: 15px;
}
.sc-total { background: #f0f9ff; border: 1px solid #bae6fd; }
.sc-percent { background: #fffbeb; border: 1px solid #fde68a; }
.sc-result { background: #f0fdf4; border: 1px solid #bbf7d0; }

.sc-icon {
    width: 40px;
    height: 40px;
    border-radius: 50%;
    display: flex;
    justify-content: center;
    align-items: center;
    color: white;
}
.sc-total .sc-icon { background: #3b82f6; }
.sc-percent .sc-icon { background: #f59e0b; }
.sc-result .sc-icon { background: #22c55e; }

.sc-content h4 {
    margin: 0 0 5px 0;
    font-size: 12px;
    color: #475569;
}
.sc-content div {
    font-size: 22px;
    font-weight: 800;
}
.sc-total .sc-content div { color: #1e3a8a; }
.sc-percent .sc-content div { color: #b45309; }
.sc-result .sc-content div { color: #166534; }

/* Remarks */
.remarks-box {
    background: #fff8eb;
    border: 1px solid #fde68a;
    border-radius: 10px;
    padding: 15px 20px;
    margin-bottom: 15px;
    position: relative;
}
.remarks-icon {
    position: absolute;
    top: -10px;
    left: 20px;
    background: #f59e0b;
    color: white;
    width: 30px;
    height: 30px;
    border-radius: 6px;
    display: flex;
    justify-content: center;
    align-items: center;
}
.remarks-title {
    margin: 0 0 15px 40px;
    font-size: 14px;
    font-weight: 700;
    color: var(--primary-color);
}
.remark-line {
    border-bottom: 1px dashed #cbd5e1;
    height: 25px;
    margin-bottom: 10px;
}

/* Signatures — fixed at bottom of the page */
.signatures {
    position: absolute;
    bottom: 18mm;
    left: 10mm;
    right: 10mm;
    display: flex;
    justify-content: space-between;
    align-items: flex-end;
    z-index: 15;
}
.sig-block {
    text-align: center;
}
.sig-line {
    border-top: 1px solid #1e293b;
    padding-top: 8px;
    font-size: 12px;
    font-weight: 700;
    color: #1e293b;
    width: 160px;
    margin-top: 10px;
}
.ribbon-badge {
    position: absolute;
    bottom: 30px;
    left: 30px;
    width: 70px;
}

/* Bottom Banner */
.bottom-banner {
    position: absolute;
    bottom: 0;
    left: 0;
    right: 0;
    height: 35px;
    background: var(--primary-color);
    color: #fff;
    text-align: center;
    font-size: 12px;
    font-weight: 600;
    font-style: italic;
    border-bottom-left-radius: 8px;
    border-bottom-right-radius: 8px;
    letter-spacing: 0.5px;
    display: flex;
    align-items: center;
    justify-content: center;
}
.bottom-banner span {
    color: var(--secondary-color);
    margin: 0 15px;
}
</style>

<div class="marksheet-wrapper">
    <div class="border-outer"></div>
    <div class="border-inner"></div>
    
    <div class="corner-accent">
        <div class="corner-bg-navy"></div>
        <div class="corner-bg-gold"></div>
        <div class="corner-bg-navy-inner"></div>
    </div>

    <div class="content-container">
        
        <!-- Header -->
        <div class="header">
            <% if (school.logo_url) { %>
                <img src="<%= school.logo_url %>" alt="Logo" class="logo">
            <% } %>
            <h1 class="school-name"><%= school.school_name %></h1>
            <% if (school.organization_name && school.organization_name !== school.school_name) { %>
            <p class="org-name"><%= school.organization_name %></p>
            <% } %>
            
            <div class="school-contact">
                <div class="contact-item">
                    <svg viewBox="0 0 24 24"><path d="M12 2C8.13 2 5 5.13 5 9c0 5.25 7 13 7 13s7-7.75 7-13c0-3.87-3.13-7-7-7zm0 9.5c-1.38 0-2.5-1.12-2.5-2.5s1.12-2.5 2.5-2.5 2.5 1.12 2.5 2.5-1.12 2.5-2.5 2.5z"/></svg>
                    <%= school.address %>
                </div>
                <div>|</div>
                <div class="contact-item">
                    <svg viewBox="0 0 24 24"><path d="M6.62 10.79c1.44 2.83 3.76 5.14 6.59 6.59l2.2-2.2c.27-.27.67-.36 1.02-.24 1.12.37 2.33.57 3.57.57.55 0 1 .45 1 1V20c0 .55-.45 1-1 1-9.39 0-17-7.61-17-17 0-.55.45-1 1-1h3.5c.55 0 1 .45 1 1 0 1.25.2 2.45.57 3.57.11.35.03.74-.25 1.02l-2.2 2.2z"/></svg>
                    <%= school.phone %>
                </div>
                <div>|</div>
                <div class="contact-item">
                    <svg viewBox="0 0 24 24"><path d="M20 4H4c-1.1 0-1.99.9-1.99 2L2 18c0 1.1.9 2 2 2h16c1.1 0 2-.9 2-2V6c0-1.1-.9-2-2-2zm0 4l-8 5-8-5V6l8 5 8-5v2z"/></svg>
                    <%= school.email %>
                </div>
            </div>
            
            <div class="divider-line"></div>
        </div>

        <!-- Banner -->
        <div class="title-banner-container">
            <svg class="banner-icon-left" viewBox="0 0 24 24" fill="var(--primary-color)"><path d="M12 3L1 9l4 2.18v6L12 21l7-3.82v-6l2-1.09V17h2V9L12 3zm6.82 6L12 12.72 5.18 9 12 5.28 18.82 9zM17 15.99l-5 2.73-5-2.73v-3.72L12 16l5-2.73v3.72z"/></svg>
            <div class="title-banner">PROGRESS REPORT CARD</div>
            <svg class="banner-icon-right" viewBox="0 0 24 24" fill="var(--primary-color)"><path d="M21 5c-1.11-.35-2.33-.5-3.5-.5-1.95 0-4.05.4-5.5 1.5-1.45-1.1-3.55-1.5-5.5-1.5S2.45 4.9 1 6v14.65c0 .25.25.5.5.5.1 0 .15-.05.25-.05C3.1 20.45 5.05 20 6.5 20c1.95 0 4.05.4 5.5 1.5 1.35-.85 3.8-1.5 5.5-1.5 1.65 0 3.35.3 4.75 1.05.1.05.15.05.25.05.25 0 .5-.25.5-.5V6c-.6-.45-1.25-.75-2-1zm0 13.5c-1.1-.35-2.3-.5-3.5-.5-1.7 0-4.15.65-5.5 1.5V8c1.35-.85 3.8-1.5 5.5-1.5 1.2 0 2.4.15 3.5.5v11.5z"/></svg>
        </div>

        <div class="academic-year">
            <div class="academic-year-badge">
                <svg viewBox="0 0 24 24" width="16" height="16" fill="currentColor"><path d="M19 3h-1V1h-2v2H8V1H6v2H5c-1.11 0-1.99.9-1.99 2L3 19c0 1.1.89 2 2 2h14c1.1 0 2-.9 2-2V5c0-1.1-.9-2-2-2zm0 16H5V8h14v11zM7 10h5v5H7z"/></svg>
                Academic Year: <%= school.academic_year || '2025-26' %>
            </div>
        </div>

        <!-- Student Info -->
        <div class="student-info-box">
            <div class="info-col">
                <div class="info-row">
                    <div class="info-label">
                        <svg viewBox="0 0 24 24"><path d="M12 12c2.21 0 4-1.79 4-4s-1.79-4-4-4-4 1.79-4 4 1.79 4 4 4zm0 2c-2.67 0-8 1.34-8 4v2h16v-2c0-2.66-5.33-4-8-4z"/></svg>
                        Name
                    </div>
                    <div class="info-value">: <%= student.stu_first_name %> <%= student.stu_last_name %></div>
                </div>
                <div class="info-row">
                    <div class="info-label">
                        <svg viewBox="0 0 24 24"><path d="M12 12c2.21 0 4-1.79 4-4s-1.79-4-4-4-4 1.79-4 4 1.79 4 4 4zm0 2c-2.67 0-8 1.34-8 4v2h16v-2c0-2.66-5.33-4-8-4z"/></svg>
                        Father's Name
                    </div>
                    <div class="info-value">: <%= student.father_name || 'N/A' %></div>
                </div>
                <div class="info-row">
                    <div class="info-label">
                        <svg viewBox="0 0 24 24"><path d="M14 2H6c-1.1 0-1.99.9-1.99 2L4 20c0 1.1.89 2 1.99 2H18c1.1 0 2-.9 2-2V8l-6-6zm2 16H8v-2h8v2zm0-4H8v-2h8v2zm-3-5V3.5L18.5 9H13z"/></svg>
                        Student ID
                    </div>
                    <div class="info-value">: <%= student.student_id %></div>
                </div>
            </div>
            <div class="info-col">
                <div class="info-row">
                    <div class="info-label">
                        <svg viewBox="0 0 24 24"><path d="M12 3L1 9l4 2.18v6L12 21l7-3.82v-6l2-1.09V17h2V9L12 3z"/></svg>
                        Class
                    </div>
                    <div class="info-value">: <%= student.class_name %></div>
                </div>
                <div class="info-row">
                    <div class="info-label">
                        <svg viewBox="0 0 24 24"><path d="M19 3H5c-1.1 0-2 .9-2 2v14c0 1.1.9 2 2 2h14c1.1 0 2-.9 2-2V5c0-1.1-.9-2-2-2zm-5 14H7v-2h7v2zm3-4H7v-2h10v2zm0-4H7V7h10v2z"/></svg>
                        Section
                    </div>
                    <div class="info-value">: <%= student.section_name %></div>
                </div>
                <div class="info-row">
                    <div class="info-label">
                        <svg viewBox="0 0 24 24"><path d="M14 2H6c-1.1 0-1.99.9-1.99 2L4 20c0 1.1.89 2 1.99 2H18c1.1 0 2-.9 2-2V8l-6-6zm2 16H8v-2h8v2zm0-4H8v-2h8v2zm-3-5V3.5L18.5 9H13z"/></svg>
                        Roll No.
                    </div>
                    <div class="info-value">: <%= student.roll_number || '-' %></div>
                </div>
            </div>
        </div>

        <!-- Marks Table -->
        <% let anySubjectFailed = false; %>
        <div class="marks-table-wrapper">
            <table>
                <thead>
                    <tr>
                        <th>Subject</th>
                        <th>Max Marks</th>
                        <th>Obtained Marks</th>
                        <th>Grade</th>
                        <th>Status</th>
                    </tr>
                </thead>
                <tbody>
                    <% if (typeof marks !== 'undefined' && marks.length > 0) { %>
                    <% anySubjectFailed = marks.some(m => Number(m.obtained_marks) < (Number(m.max_marks) * 0.35)); %>
                        <% marks.forEach(m => { %>
                            <tr>
                                <td><%= m.subject_name %></td>
                                <td><%= m.max_marks %></td>
                                <td><%= m.obtained_marks %></td>
                                <td><%= m.grade || '-' %></td>
                                <td style="color: <%= m.obtained_marks >= (m.max_marks * 0.35) ? '#166534' : '#b91c1c' %>;">
                                    <%= m.obtained_marks >= (m.max_marks * 0.35) ? 'PASS' : 'FAIL' %>
                                </td>
                            </tr>
                        <% }); %>
                    <% } else { %>
                        <tr>
                            <td colspan="5">
                                <div class="empty-state">
                                    <svg viewBox="0 0 24 24"><path d="M21 5c-1.11-.35-2.33-.5-3.5-.5-1.95 0-4.05.4-5.5 1.5-1.45-1.1-3.55-1.5-5.5-1.5S2.45 4.9 1 6v14.65c0 .25.25.5.5.5.1 0 .15-.05.25-.05C3.1 20.45 5.05 20 6.5 20c1.95 0 4.05.4 5.5 1.5 1.35-.85 3.8-1.5 5.5-1.5 1.65 0 3.35.3 4.75 1.05.1.05.15.05.25.05.25 0 .5-.25.5-.5V6c-.6-.45-1.25-.75-2-1zm0 13.5c-1.1-.35-2.3-.5-3.5-.5-1.7 0-4.15.65-5.5 1.5V8c1.35-.85 3.8-1.5 5.5-1.5 1.2 0 2.4.15 3.5.5v11.5z"/></svg>
                                    <div>No academic data available for this period</div>
                                </div>
                            </td>
                        </tr>
                    <% } %>
                </tbody>
            </table>
        </div>

        <!-- Summary -->
        <div class="summary-container">
            <div class="summary-card sc-total">
                <div class="sc-icon">
                    <svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor"><path d="M19 3h-4.18C14.4 1.84 13.3 1 12 1c-1.3 0-2.4.84-2.82 2H5c-1.1 0-2 .9-2 2v14c0 1.1.9 2 2 2h14c1.1 0 2-.9 2-2V5c0-1.1-.9-2-2-2zm-7 0c.55 0 1 .45 1 1s-.45 1-1 1-1-.45-1-1 .45-1 1-1zm-2 14l-4-4 1.41-1.41L10 14.17l6.59-6.59L18 9l-8 8z"/></svg>
                </div>
                <div class="sc-content">
                    <h4>Total</h4>
                    <div><%= typeof totalMarks !== 'undefined' ? totalMarks : '0' %> / <%= typeof maxTotal !== 'undefined' ? maxTotal : '0' %></div>
                </div>
            </div>
            <div class="summary-card sc-percent">
                <div class="sc-icon">
                    <svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor"><path d="M11 2v20c-5.07-.5-9-4.79-9-10s3.93-9.5 9-10zm2.03 0v8.99H22c-.47-4.74-4.24-8.52-8.97-8.99zm0 11.01V22c4.74-.47 8.5-4.25 8.97-8.99h-8.97z"/></svg>
                </div>
                <div class="sc-content">
                    <h4>Percentage</h4>
                    <div><%= typeof percentage !== 'undefined' ? percentage : '0' %>%</div>
                </div>
            </div>
            <div class="summary-card sc-result">
                <div class="sc-icon">
                    <svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor"><path d="M20.2 2H19.5v1.5H20.2c.8 0 1.5.7 1.5 1.5v2.8c0 2.2-1.8 4-4 4h-1.5v2.5c0 1.4-1.1 2.5-2.5 2.5h-1v4h4v1.5H8.8v-1.5h4v-4h-1c-1.4 0-2.5-1.1-2.5-2.5V11.8H7.8c-2.2 0-4-1.8-4-4V5c0-.8.7-1.5 1.5-1.5h.7V2H5.3C3.5 2 2 3.5 2 5.3v2.8C2 11.2 4.4 13.8 7.5 14.3v.5C7.5 16.5 8.9 18 10.8 18h.5v4H7.8v3h8.5v-3h-3.5v-4h.5c1.9 0 3.3-1.5 3.3-3.3v-.5c3.1-.5 5.5-3.1 5.5-6.2V5.3C22 3.5 20.5 2 18.7 2h1.5z"/></svg>
                </div>
                <div class="sc-content">
                    <h4>Result</h4>
                    <%
                      const isOverallPass = !anySubjectFailed && typeof percentage !== 'undefined' && Number(percentage) >= 35;
                    %>
                    <div style="color: <%= isOverallPass ? '#166534' : '#b91c1c' %>; font-weight: 800;">
                        <%= isOverallPass ? 'PASS' : 'FAIL' %>
                    </div>
                </div>
            </div>
        </div>

        <!-- Remarks -->
        <div class="remarks-box">
            <div class="remarks-icon">★</div>
            <h4 class="remarks-title">Remark / Teacher's Comment</h4>
            <div class="remark-line"></div>
            <div class="remark-line"></div>
        </div>

        <!-- Signatures (absolutely positioned at bottom) -->
        </div><!-- end content-container -->

        <div class="signatures">
            <div class="sig-block">
                <div style="display: flex; align-items: center; gap: 5px; color: var(--primary-color); font-weight: 700; margin-bottom: 5px; justify-content: center;">
                    <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor"><path d="M19 3h-1V1h-2v2H8V1H6v2H5c-1.11 0-1.99.9-1.99 2L3 19c0 1.1.89 2 2 2h14c1.1 0 2-.9 2-2V5c0-1.1-.9-2-2-2zm0 16H5V8h14v11zM7 10h5v5H7z"/></svg>
                    Date of Issue
                </div>
                <div style="font-weight: 700; font-size: 14px;"><%= new Date().toLocaleDateString('en-GB', { day: '2-digit', month: 'short', year: 'numeric' }) %></div>
            </div>

            <div class="sig-block">
                <% if (school.signature_url) { %>
                    <img src="<%= school.signature_url %>" alt="Signature" style="height: 40px; object-fit: contain;">
                <% } else { %>
                    <div style="height: 40px;"></div>
                <% } %>
                <div class="sig-line">PRINCIPAL SIGNATURE</div>
            </div>
        </div>
        <!-- Decorative star (repositioned) -->

    </div>
    
    <div class="bottom-banner">
        <span>★</span> Excellence in Education, Every Step of the Way. <span>★</span>
    </div>
</div>
