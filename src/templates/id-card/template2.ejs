<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<title>ID Card Landscape</title>
<%- include('../common/theme_variables', { theme: school.document_theme, is_theme_enabled: school.is_document_theme_enabled }) %>
<%
  const pc = 'var(--primary-color)';
  const sc = 'var(--secondary-color)';
  const initials = ((student.stu_first_name||'').charAt(0) + (student.stu_last_name||'').charAt(0)).toUpperCase() || '?';
  const dobStr = student.date_of_birth ? new Date(student.date_of_birth).toLocaleDateString('en-GB',{day:'2-digit',month:'2-digit',year:'numeric'}) : null;
  const photoSrc = photoDataUrl || student.profile_url || null;
  const logoSrc  = logoDataUrl  || school.logo_url    || null;
  const sigSrc   = signatureDataUrl || school.signature_url || null;
  const sansthaName = (school.organization_name && school.organization_name.trim()) ? school.organization_name.trim() : null;
  const rollNo = student.student_id;
  const acadYear = school.academic_year || '2025-26';
%>
<style>
* { margin:0; padding:0; box-sizing:border-box; }
html, body {
  width: 324px; height: 204px; overflow: hidden;
  background: transparent;
  -webkit-print-color-adjust: exact; print-color-adjust: exact;
  font-family: 'Segoe UI', Arial, sans-serif;
}
.card {
  width: 324px; height: 204px;
  display: flex; flex-direction: column;
  overflow: hidden; border-radius: 8px;
  background: #fff;
}

/* ── Main row ── */
.main { display: flex; flex: 1; min-height: 0; overflow: hidden; }

/* ──────────────────────────────────────────
   LEFT PANEL  (mirrors the vertical header)
────────────────────────────────────────── */
.left {
  width: 118px; flex-shrink: 0;
  background: <%= pc %>;
  display: flex; flex-direction: column; align-items: center;
  padding: 7px 6px 5px;
  overflow: hidden;
}

/* Logo circle — identical to .logo-wrap in template1 */
.logo-wrap {
  width: 28px; height: 28px; border-radius: 50%;
  border: 1px solid #fff; background: #fff;
  overflow: hidden; flex-shrink: 0;
  display: flex; align-items: center; justify-content: center;
  box-shadow: 0 0 0 1px rgba(201,168,76,0.5);
  margin-bottom: 2px;
}
.logo-wrap img { width: 100%; height: 100%; object-fit: contain; }
.logo-wrap .lt { font-size: 7px; font-weight: 800; color: <%= pc %>; }

/* Org name — gold, bold, NON-italic (matches .org-yellow in template1) */
.org-yellow {
  font-size: 5px; font-weight: 800; color: #facc15;
  text-align: center; line-height: 1.2; margin-bottom: 2px;
}

/* Gold dot divider — identical to template1 */
.gold-div {
  display: flex; align-items: center; justify-content: center;
  width: 55%; margin: 2px 0 3px;
}
.gold-div::before, .gold-div::after {
  content: ''; flex: 1; height: 1px; background: #facc15;
}
.gold-div .dot {
  width: 3px; height: 3px; background: #facc15;
  border-radius: 50%; margin: 0 2px;
}

/* School name — uppercase bold white (matches .sn-caps in template1) */
.sn-caps {
  font-size: 7.5px; font-weight: 800; color: #fff; text-transform: uppercase;
  text-align: center; line-height: 1.1; margin-bottom: 3px;
  padding: 0 2px;
}

/* Address with pin icon — matches .hdr-addr in template1 */
.hdr-addr {
  display: flex; align-items: flex-start; justify-content: center;
  width: 100%; gap: 2px;
}
.hdr-addr-icon {
  width: 5px; height: 5px; display: flex; align-items: center;
  justify-content: center; margin-top: 0.2px; flex-shrink: 0;
}
.hdr-addr-icon svg { width: 100%; height: 100%; fill: #fff; }
.hdr-addr-text {
  font-size: 4px; color: #fff; text-align: center; line-height: 1.1;
}

/* Photo — rectangular with rounded corners (landscape layout) */
.photo-wrap {
  width: 60px; height: 66px;
  border: 2px solid #fff; border-radius: 6px;
  overflow: hidden; flex-shrink: 0;
  background: #e2e8f0;
  display: flex; align-items: center; justify-content: center;
  box-shadow: 0 2px 6px rgba(0,0,0,0.2);
  margin-top: 6px;
}
.photo-wrap img { width: 100%; height: 100%; object-fit: cover; }
.photo-wrap .ph-init { font-size: 18px; font-weight: 700; color: #475569; }

/* ──────────────────────────────────────────
   RIGHT PANEL
────────────────────────────────────────── */
.right {
  flex: 1; display: flex; flex-direction: column;
  padding: 8px 10px 5px 10px; overflow: hidden;
  background: #fff;
}

/* Student name */
.stu-name {
  font-size: 14px; font-weight: 800; color: #1e293b;
  line-height: 1.1; white-space: nowrap;
  overflow: hidden; text-overflow: ellipsis;
  margin-bottom: 3px;
}

/* Class badge — pill with primary-color background, identical to template1 */
.cls-badge {
  display: flex; margin-bottom: 4px;
}
.cls-badge span {
  font-size: 6.5px; font-weight: 700; color: #fff;
  background: <%= pc %>;
  border-radius: 12px; padding: 2px 10px;
  white-space: nowrap;
}

/* ── Detail rows — same dashed divider style as template1 ── */
.rows-container {
  display: flex; flex-direction: column; width: 100%;
  background-image: linear-gradient(to right, #cbd5e1 50%, transparent 50%);
  background-position: top; background-size: 4px 1px; background-repeat: repeat-x;
}
.row {
  display: flex; align-items: center;
  padding: 3.5px 0;
  background-image: linear-gradient(to right, #cbd5e1 50%, transparent 50%);
  background-position: bottom; background-size: 4px 1px; background-repeat: repeat-x;
}
.row:last-child { background-image: none; }

/* Icon — fixed black, same as template1 */
.icon {
  width: 7px; height: 7px; margin-right: 4px;
  display: flex; align-items: center; justify-content: center;
  flex-shrink: 0;
}
.icon svg { width: 100%; height: 100%; fill: #1e293b; }

/* Field label */
.rl {
  font-size: 5px; font-weight: 800;
  color: #1e293b; text-transform: uppercase; letter-spacing: 0.02em;
  width: 68px; flex-shrink: 0; line-height: 1.1;
}

/* Colon separator */
.rc { font-size: 5px; font-weight: 800; color: #475569; margin-right: 3px; line-height: 1; }

/* Value */
.rv {
  font-size: 5.5px; font-weight: 800; color: #0f172a;
  flex: 1; line-height: 1.1; overflow: hidden; text-overflow: ellipsis; white-space: nowrap;
}
/* Multi-line address value */
.row-address { align-items: flex-start; }
.row-address .rv { white-space: normal; min-height: 10px; height: auto; }

/* ── Bottom area ── */
.bottom-area {
  flex-shrink: 0;
  margin-top: auto;
}

/* Signature — identical styling to template1 (blue) */
.sig-container {
  display: flex; justify-content: flex-end;
  padding-right: 2px;
  margin-bottom: 1px;
}
.sig {
  display: flex; flex-direction: column; align-items: center;
}
.sig img { height: 12px; max-width: 44px; object-fit: contain; }
.sig-line { width: 44px; border-bottom: 0.8px solid #1d4ed8; }
.sig-lbl {
  font-size: 3.5px; font-weight: 800;
  color: #1d4ed8; text-transform: uppercase; margin-top: 2px;
}
</style>
</head>
<body>
<div class="card">
  <div class="main">

    <!-- ════════════ LEFT PANEL ════════════ -->
    <div class="left">
      <!-- School logo -->
      <div class="logo-wrap">
        <% if (logoSrc) { %><img src="<%= logoSrc %>" alt="Logo">
        <% } else { %><span class="lt"><%= (school.school_name||'').charAt(0) %></span><% } %>
      </div>

      <!-- Org name — gold bold (same as template1) -->
      <% if (sansthaName) { %>
        <div class="org-yellow"><%= sansthaName %></div>
      <% } %>

      <!-- Gold dot divider — between org and school name, same order as template1 -->
      <div class="gold-div"><div class="dot"></div></div>

      <!-- School name — uppercase bold white -->
      <div class="sn-caps"><%= school.school_name %></div>

      <!-- Address with pin icon — same as template1 header -->
      <% if (school.address) { %>
        <div class="hdr-addr">
          <div class="hdr-addr-icon"><svg viewBox="0 0 24 24"><path d="M12 2C8.13 2 5 5.13 5 9c0 5.25 7 13 7 13s7-7.75 7-13c0-3.87-3.13-7-7-7zm0 9.5c-1.38 0-2.5-1.12-2.5-2.5s1.12-2.5 2.5-2.5 2.5 1.12 2.5 2.5-1.12 2.5-2.5 2.5z"/></svg></div>
          <div class="hdr-addr-text"><%= school.address %></div>
        </div>
      <% } %>

      <!-- Student photo -->
      <div class="photo-wrap">
        <% if (photoSrc) { %><img src="<%= photoSrc %>" alt="Photo">
        <% } else { %><span class="ph-init"><%= initials %></span><% } %>
      </div>
    </div>

    <!-- ════════════ RIGHT PANEL ════════════ -->
    <div class="right">
      <!-- Student name -->
      <div class="stu-name">
        <% if (student.stu_first_name || student.stu_last_name) { %>
          <%= student.stu_first_name || '' %> <%= student.stu_last_name || '' %>
        <% } %>
      </div>

      <!-- Class badge — pill (same as template1) -->
      <div class="cls-badge">
        <span>Class <%= student.class_name %><% if (student.section_name) { %>-<%= student.section_name %><% } %></span>
      </div>

      <!-- Data rows -->
      <div class="rows-container">

        <!-- ID / Roll Number -->
        <div class="row">
          <div class="icon"><svg viewBox="0 0 24 24"><path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2zm0 2v12h16V6H4zm3 3h4v4H7V9zm5 0h5v1.5h-5V9zm0 2.5h5V13h-5v-1.5z"/></svg></div>
          <span class="rl">ID Number</span><span class="rc">:</span>
          <span class="rv"><%= rollNo %></span>
        </div>

        <% if (dobStr) { %>
        <div class="row">
          <div class="icon"><svg viewBox="0 0 24 24"><path d="M19 3h-1V1h-2v2H8V1H6v2H5c-1.1 0-2 .9-2 2v14c0 1.1.9 2 2 2h14c1.1 0 2-.9 2-2V5c0-1.1-.9-2-2-2zm0 16H5V8h14v11z"/></svg></div>
          <span class="rl">Date of Birth</span><span class="rc">:</span>
          <span class="rv"><%= dobStr %></span>
        </div>
        <% } %>

        <% if (student.blood_group) { %>
        <div class="row">
          <div class="icon"><svg viewBox="0 0 24 24"><path d="M12 2c-5.33 4.55-8 8.48-8 11.8 0 4.98 3.8 8.2 8 8.2s8-3.22 8-8.2c0-3.32-2.67-7.25-8-11.8z"/></svg></div>
          <span class="rl">Blood Group</span><span class="rc">:</span>
          <span class="rv"><%= student.blood_group %></span>
        </div>
        <% } %>

        <% if (student.primary_contact) { %>
        <div class="row">
          <div class="icon"><svg viewBox="0 0 24 24"><path d="M6.62 10.79c1.44 2.83 3.76 5.15 6.59 6.59l2.2-2.2c.28-.28.67-.36 1.02-.25 1.12.37 2.32.57 3.57.57.55 0 1 .45 1 1V20c0 .55-.45 1-1 1-9.39 0-17-7.61-17-17 0-.55.45-1 1-1h3.5c.55 0 1 .45 1 1 0 1.25.2 2.45.57 3.57.11.35.03.74-.25 1.02l-2.2 2.2z"/></svg></div>
          <span class="rl">Parent Contact No.</span><span class="rc">:</span>
          <span class="rv"><%= student.primary_contact %></span>
        </div>
        <% } %>

        <% if (student.father_name) { %>
        <div class="row">
          <div class="icon"><svg viewBox="0 0 24 24"><path d="M12 12c2.21 0 4-1.79 4-4s-1.79-4-4-4-4 1.79-4 4 1.79 4 4 4zm0 2c-2.67 0-8 1.34-8 4v2h16v-2c0-2.66-5.33-4-8-4z"/></svg></div>
          <span class="rl">Father Name</span><span class="rc">:</span>
          <span class="rv"><%= student.father_name %></span>
        </div>
        <% } %>

        <% if (acadYear) { %>
        <div class="row">
          <div class="icon"><svg viewBox="0 0 24 24"><path d="M19 3h-1V1h-2v2H8V1H6v2H5c-1.1 0-2 .9-2 2v14c0 1.1.9 2 2 2h14c1.1 0 2-.9 2-2V5c0-1.1-.9-2-2-2zm0 16H5V8h14v11z"/></svg></div>
          <span class="rl">Academic Year</span><span class="rc">:</span>
          <span class="rv"><%= acadYear %></span>
        </div>
        <% } %>

        <% if (student.address) { %>
        <div class="row row-address">
          <div class="icon"><svg viewBox="0 0 24 24"><path d="M12 2C8.13 2 5 5.13 5 9c0 5.25 7 13 7 13s7-7.75 7-13c0-3.87-3.13-7-7-7zm0 9.5c-1.38 0-2.5-1.12-2.5-2.5s1.12-2.5 2.5-2.5 2.5 1.12 2.5 2.5-1.12 2.5-2.5 2.5z"/></svg></div>
          <span class="rl">Address</span><span class="rc">:</span>
          <span class="rv"><%= student.address %></span>
        </div>
        <% } %>

      </div>

      <!-- Signature — separated from data rows, no overlap -->
      <div class="bottom-area">
        <div class="sig-container">
          <div class="sig">
            <% if (sigSrc) { %>
              <img src="<%= sigSrc %>" alt="Sig">
            <% } else { %>
              <div class="sig-line"></div>
            <% } %>
            <div class="sig-lbl">AUTHORIZED SIGNATORY</div>
          </div>
        </div>
      </div>
    </div>

  </div>

  <!-- ════════════ FOOTER (matches template1 footer-wrap) ════════════ -->
  <div style="flex-shrink:0; display:flex; flex-direction:column;">
    <div style="height:1.5px; background:#facc15;"></div>
    <div style="height:16px; background:<%= pc %>; display:flex; align-items:center; justify-content:center;">
      <span style="font-size:5.5px; font-weight:600; color:#fff; letter-spacing:0.02em;">Valid for Academic Session <%= acadYear %></span>
    </div>
  </div>

</div>
</body>
</html>
