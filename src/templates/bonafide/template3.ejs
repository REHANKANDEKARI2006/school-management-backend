<head>
    <meta charset="utf-8">
    <title>Bonafide Certificate - Template 3</title>
    <%- include('../common/styles') %>
    <style>
        body {
            padding: 20px;
            background: #fff;
        }
        .decorative-cert {
            border: 20px solid transparent;
            border-image: url('https://www.transparenttextures.com/patterns/cubes.png') 30 stretch;
            background-color: white;
            padding: 60px;
            min-height: 1000px;
            position: relative;
            outline: 10px double var(--primary-color);
            outline-offset: -10px;
        }
        .decorative-header {
            text-align: center;
            margin-bottom: 50px;
        }
        .decorative-header h1 {
            font-size: 32px;
            color: var(--primary-color);
            margin-bottom: 10px;
        }
        .decorative-body {
            font-family: 'Outfit', serif;
            font-size: 22px;
            text-align: center;
            line-height: 2;
        }
        .student-highlight {
            font-size: 28px;
            font-weight: 800;
            color: var(--primary-color);
            text-decoration: underline;
        }
        .footer-decorative {
            margin-top: 100px;
            display: flex;
            justify-content: space-around;
            align-items: center;
        }
        .seal-embossed {
            width: 120px;
            height: 120px;
            background: #f8f9fa;
            border-radius: 50%;
            display: flex;
            align-items: center;
            justify-content: center;
            font-weight: 800;
            color: var(--secondary-color);
            border: 2px dashed var(--border-color);
        }
    </style>
</head>
<body>
    <div class="decorative-cert doc-container">
        <div class="decorative-header">
            <h1 class="premium-heading"><%= school.school_name %></h1>
            <p><%= school.address %></p>
        </div>
        
        <div class="decorative-body">
            This is to certify the academic merit of<br>
            <span class="student-highlight"><%= student.stu_first_name %> <%= student.stu_last_name %></span><br>
            Who is a bonafide student of this institution in Class <%= student.class_name %>.<br>
            Session: <%= school.academic_year %><br>
            Date of Birth: <%= new Date(student.date_of_birth).toLocaleDateString() %>
        </div>

        <div class="footer-decorative">
            <div style="text-align: center;">
                <img src="<%= signatureUrl %>" style="height: 50px;"><br>
                <strong>Principal</strong>
            </div>
            <div class="seal-embossed">SEAL</div>
            <div style="text-align: center;">
                <br><br>
                <strong>Authorized by Office</strong>
            </div>
        </div>
    </div>
</body>
</html>
